# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc

# Environment variables
.env

# Generated artifacts (don’t push results)
artifacts/*.csv
artifacts/*.parquet
artifacts/*.json

# Data
data/*.csv

# keep artifacts folder, but ignore heavy raw outputs
artifacts/**/*.parquet
artifacts/**/*.pkl
artifacts/**/*.joblib

# allow images and readmes
!artifacts/**/*.png
!artifacts/**/*.jpg
!artifacts/**/*.jpeg
!artifacts/**/*.svg
!artifacts/**/README.md
